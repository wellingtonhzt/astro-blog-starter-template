---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>🧑‍🚀 WL Infra!</h1>
			<p>
				Projetos de Infraestrutura com serviços open-source e virtualização.

<img src="/home-infra.png" alt="WL Infra Lab - Proxmox Environment - Wellington Lima" style="width: 100%; max-width: 900px; border-radius: 6px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); margin-bottom: 25px;" />
			</p>
			
	</body>
</html>
