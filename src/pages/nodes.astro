    <div class="grid md:grid-cols-2 gap-10">
        
        <a href="https://pvelab.wl-infra.uk/" target="_blank" class="glass p-10 rounded-3xl transition-all duration-500 hover:scale-105 border-sky-500/30 hover:border-sky-400 group">
