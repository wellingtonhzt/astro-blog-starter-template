---
// src/pages/nodes.astro
---

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WL-INFRA // ACCESS_TERMINAL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #010409;
            background-image: url('data:image/svg+xml;base64,');
            color: #00FF00;
            font-family: 'Fira Mono', monospace;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            margin: 0;
            padding: 20px;
        }
        .crt-glow { text-shadow: 0 0 8px rgba(0, 255, 0, 0.7); }
        a { color: inherit; text-decoration: none !important; }
        .terminal-card {
            background-color: rgba(1, 4, 9, 0.9);
            border: 2px solid #00FF00;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
            transition: all 0.2s ease;
        }
        .terminal-card:hover {
            background-color: #00FF00;
            color: #010409;
            box-shadow: 0 0 30px rgba(0, 255, 0, 0.6);
        }
        .terminal-icon { filter: drop-shadow(0 0 2px rgba(0, 255, 0, 0.6)); transition: all 0.2s; }
        .terminal-card:hover .terminal-icon { filter: invert(1) brightness(0.1); }
    </style>
</head>
<body>

    <header class="w-full max-w-4xl flex flex-col items-center text-center mb-16 crt-glow">
        <div class="mb-6 p-2 border-2 border-dashed border-[#00FF00]/50 rounded-xl">
            <img src="data:image/png;base64," class="w-16 h-16 terminal-icon" />
        </div>
        <h1 class="text-4xl font-bold tracking-tight">&gt; WL-INFRA_NODES</h1>
        <div class="mt-4 text-[10px] font-bold border border-[#00FF00] px-3 py-1">[ HORIZONTE.CE // SECURED_SHELL ]</div>
    </header>

    <main class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-10">
        <a href="https://pvelab.wl-infra.uk/" target="_blank" class="terminal-card p-10 rounded-xl block group">
            <div class="flex flex-col items-center text-center">
                <img src="data:image/png;base64," class="w-16 h-16 terminal-icon mb-6" />
                <h2 class="text-2xl font-bold mb-4 crt-glow"># pvelab.local</h2>
                <p class="text-xs mb-10 group-hover:text-[#010409]">[ DELL_OPTIPLEX_8080 ]<br/>Homologação_CTs_VMs.</p>
                <div class="px-4 py-2 border-2 border-[#00FF00] font-bold group-hover:border-[#010409]">ACCESS_CONSOLE</div>
            </div>
        </a>

        <a href="https://pvesamu.wl-infra.uk/" target="_blank" class="terminal-card p-10 rounded-xl block group">
            <div class="flex flex-col items-center text-center">
                <img src="data:image/png;base64," class="w-16 h-16 terminal-icon mb-6" />
                <h2 class="text-2xl font-bold mb-4 crt-glow"># pvesamu.main</h2>
                <p class="text-xs mb-10 group-hover:text-[#010409]">[ PROD_ENV ]<br/>Storage_&_Critical_DB.</p>
                <div class="px-4 py-2 border-2 border-[#00FF00] font-bold group-hover:border-[#010409]">ACCESS_CONSOLE</div>
            </div>
        </a>
    </main>

    <footer class="mt-20 text-center crt-glow">
        <div class="text-[10px] font-bold">
            [ TERMINAL_SECURED_BY_CLOUDFLARE_ZERO_TRUST ]
        </div>
    </footer>

</body>
</html>
