---
// src/pages/nodes.astro
---

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WL-INFRA // ACCESS_TERMINAL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* RESET E FUNDO PRETO ABSOLUTO */
        body {
            background-color: #000000 !important;
            color: #00FF00;
            font-family: 'Fira Mono', monospace;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow-x: hidden;
        }

        /* EFEITO DE SCANLINE MAIS ESCURO */
        body::before {
            content: " ";
            display: block;
            position: fixed;
            top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.5) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
            z-index: 2;
            background-size: 100% 3px, 2px 100%;
            pointer-events: none;
        }

        .crt-glow { 
            text-shadow: 0 0 10px #00FF00; 
        }
        
        /* FORÇAR VERDE NOS ÍCONES */
        .fa-solid, .fa-terminal, .fa-flask-vial, .fa-microchip, .fa-user-shield {
            color: #00FF00 !important;
            display: inline-block;
        }

        /* CARD SEM FUNDO CINZA */
        .terminal-card {
            background-color: transparent;
            border: 2px solid #00FF00;
            transition: all 0.2s ease;
            position: relative;
            z-index: 5;
        }

        .terminal-card:hover {
            background-color: #00FF00;
            box-shadow: 0 0 30px #00FF00;
        }

        /* INVERTER CORES NO HOVER */
        .terminal-card:hover * {
            color: #000000 !important;
            text-shadow: none !important;
        }

        .connect-btn {
            border: 1px solid #00FF00;
        }
        .terminal-card:hover .connect-btn {
            border-color: #000000;
        }
    </style>
</head>
<body class="p-4">

    <div class="max-w-4xl w-full flex flex-col items-center">
        
        <header class="text-center mb-16 crt-glow">
            <div class="text-6xl mb-6">
                <i class="fa-solid fa-terminal"></i>
            </div>
            <h1 class="text-4xl md:text-5xl font-bold tracking-tighter">
                > WL-INFRA_NODES
            </h1>
            <div class="mt-4 text-sm font-bold border border-[#00FF00] px-4 py-1 inline-block">
                [ HORIZONTE.CE // SECURED_SHELL ]
            </div>
        </header>

        <main class="grid grid-cols-1 md:grid-cols-2 gap-10 w-full">
            
            <a href="https://pvelab.wl-infra.uk/" target="_blank" class="terminal-card p-10 rounded-lg block text-center group">
                <div class="text-5xl mb-6">
                    <i class="fa-solid fa-flask-vial"></i>
                </div>
                <h2 class="text-2xl font-bold mb-4 crt-glow"># pvelab.local</h2>
                <p class="text-xs mb-8 font-bold">
                    [ DELL_OPTIPLEX_8080 ]<br/>
                    HOMOLOG_ENV // CT_VM_ACTIVE
                </p>
                <div class="connect-btn py-2 px-4 text-sm font-bold">
                    EXEC :: CONNECT
                </div>
            </a>

            <a href="https://pvesamu.wl-infra.uk/" target="_blank" class="terminal-card p-10 rounded-lg block text-center group">
                <div class="text-5xl mb-6">
                    <i class="fa-solid fa-microchip"></i>
                </div>
                <h2 class="text-2xl font-bold mb-4 crt-glow"># pvesamu.main</h2>
                <p class="text-xs mb-8 font-bold">
                    [ PRODUCTION_ENV ]<br/>
                    STORAGE_MASTER // CRITICAL_DB
                </p>
                <div class="connect-btn py-2 px-4 text-sm font-bold">
                    EXEC :: CONNECT
                </div>
            </a>

        </main>

        <footer class="mt-20 text-center crt-glow">
            <div class="text-xs font-bold flex items-center justify-center gap-3">
                <i class="fa-solid fa-user-shield"></i>
                [ AUTH_MFA // CLOUDFLARE_ZERO_TRUST_ENABLED ]
            </div>
        </footer>
    </div>

</body>
</html>
