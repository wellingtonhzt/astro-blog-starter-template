---
// src/pages/nodes.astro
---

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WL-INFRA // ACCESS_TERMINAL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* CSS Customizado para o tema Terminal Matrix */
        
        body {
            /* Fundo: Cor escura com imagem de padrão Matrix sutil */
            background-color: #010409;
            background-image: url('data:image/svg+xml;base64,');
            color: #00FF00; /* Verde Matrix */
            font-family: 'Fira Mono', monospace; /* Fonte Terminal */
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            margin: 0;
            padding: 20px;
        }

        /* Efeito de brilho "CRT" no texto */
        .crt-glow {
            text-shadow: 0 0 8px rgba(0, 255, 0, 0.7);
        }

        /* Sobrescrever padrões do navegador para links */
        a {
            color: inherit;
            text-decoration: none !important;
        }

        /* Card estilo terminal */
        .terminal-card {
            background-color: rgba(1, 4, 9, 0.9); /* Quase preto e opaco */
            border: 2px solid #00FF00;
            box-shadow: 0 0 15px rgba(0, 255, 0, 0.3);
            transition: all 0.2s ease;
        }

        /* Efeito de seleção "Terminal" ao passar o mouse */
        .terminal-card:hover {
            background-color: #00FF00;
            color: #010409; /* Inverte cores */
            box-shadow: 0 0 30px rgba(0, 255, 0, 0.6);
        }

        /* Forçar ícones pixelados a ficarem verdes, exceto no hover */
        .terminal-icon {
            filter: drop-shadow(0 0 2px rgba(0, 255, 0, 0.6));
        }
        
        .terminal-card:hover .terminal-icon {
            filter: invert(1) brightness(0.1); /* Ícone fica preto no hover */
        }

    </style>
</head>
<body>

    <header class="w-full max-w-4xl flex flex-col items-center text-center mb-20 crt-glow">
        
        <div class="mb-6 p-1 border-2 border-dashed border-[#00FF00]/50 rounded-xl">
            <img src="https://img.icons8.com/pixel-surfers/128/00FF00/database.png" alt="Servidor Pixelado" class="w-20 h-20 terminal-icon"/>
        </div>

        <h1 class="text-4xl md:text-5xl font-bold tracking-tight">
            &gt; WL-INFRA_NODES
        </h1>
        
        <div class="flex items-center mt-4 text-xs font-bold uppercase tracking-widest gap-2">
            [ SECURED_ACCESS // HORIZONTE.CE ]
        </div>
    </header>

    <main class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-10">
        
        <a href="https://pvelab.wl-infra.uk/" target="_blank" class="terminal-card p-10 rounded-xl block group">
            <div class="flex flex-col items-center text-center">
                
                <img src="https://img.icons8.com/pixel-surfers/128/00FF00/test-tube.png" alt="Lab Icon" class="w-16 h-16 terminal-icon mb-6"/>
                
                <h2 class="text-3xl font-bold mb-4 crt-glow group-hover:text-[#010409] group-hover:text-shadow-none">
                    # pvelab.local
                </h2>
                
                <p class="text-sm mb-12 leading-relaxed font-normal group-hover:text-[#010409]">
                    [ TEST_ENV ] :: DELL_OPTIPLEX_8080.
                    Homologação_CTs_VMs_ativos.
                </p>
                
                <div class="px-5 py-2 border-2 border-[#00FF00] font-bold group-hover:border-[#010409] group-hover:bg-[#010409] group-hover:text-[#00FF00]">
                    &gt; CONECTAR_AGORA
                </div>
            </div>
        </a>

        <a href="https://pvesamu.wl-infra.uk/" target="_blank" class="terminal-card p-10 rounded-xl block group">
            <div class="flex flex-col items-center text-center">
                
                <img src="https://img.icons8.com/pixel-surfers/128/00FF00/cpu.png" alt="Prod Icon" class="w-16 h-16 terminal-icon mb-6"/>
                
                <h2 class="text-3xl font-bold mb-4 crt-glow group-hover:text-[#010409] group-hover:text-shadow-none">
                    # pvesamu.main
                </h2>
                
                <p class="text-sm mb-12 leading-relaxed font-normal group-hover:text-[#010409]">
                    [ PROD_ENV ] :: Servidor_Principal_Crítico.
                    Banco_Dados_Ativo_Storage_Ativo.
                </p>
                
                <div class="px-5 py-2 border-2 border-[#00FF00] font-bold group-hover:border-[#010409] group-hover:bg-[#010409] group-hover:text-[#00FF00]">
                    &gt; CONECTAR_AGORA
                </div>
            </div>
        </a>

    </main>

    <footer class="mt-28 text-center crt-glow">
        <div class="inline-flex items-center text-xs font-bold gap-3">
            <img src="https://img.icons8.com/pixel-surfers/32/00FF00/lock.png" alt="Cadeado Pixelado" class="w-4 h-4 terminal-icon"/>
            TERMINAL_SECURED_BY :: CLOUDFLARE_ZT // MFA_ACTIVE
        </div>
    </footer>

</body>
</html>
