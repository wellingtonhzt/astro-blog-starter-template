---
// src/pages/nodes.astro
---

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WL-INFRA Nodes | Gerenciamento</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        /* Corrigir o conflito de links do navegador e garantir as cores certas */
        body {
            background-color: #0f172a; /* Slate 900 */
            color: #f1f5f9; /* Slate 100 */
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }

        /* Sobrescrever padrões do navegador para links */
        a {
            color: inherit; /* Seguir a cor do texto do elemento pai */
            text-decoration: none; /* Remover sublinhado genérico */
        }

        /* Efeito de Vidro (Glassmorphism) para os cards */
        .glass-card {
            background-color: rgba(30, 41, 59, 0.6); /* Slate 800 com transparência */
            backdrop-filter: blur(12px);
            border: 1px solid rgba(56, 189, 248, 0.2); /* Borda sutil na cor cyan */
        }

        /* Efeito de realce ao passar o mouse */
        .glass-card:hover {
            transform: translateY(-5px);
            border-color: rgba(34, 211, 238, 0.6); /* Cyan 400 */
            box-shadow: 0 10px 30px -10px rgba(34, 211, 238, 0.2); /* Sombra suave */
        }
    </style>
</head>
<body class="flex flex-col items-center p-6 md:p-12">

    <header class="w-full max-w-5xl flex flex-col items-center text-center mb-16 mt-8">
        
        <div class="mb-6 p-4 bg-cyan-950/40 rounded-full border border-cyan-800">
            <i data-lucide="database" class="w-16 h-16 text-cyan-400"></i>
        </div>

        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-white">
            WL-INFRA <span class="text-cyan-400">Nodes</span>
        </h1>
        
        <div class="flex items-center mt-3 text-slate-400 font-mono text-xs uppercase tracking-widest gap-2 px-3 py-1 rounded-full border border-slate-700 bg-slate-800/60">
            <i data-lucide="map-pin" class="w-4 h-4 text-cyan-600"></i>
            Acesso Restrito - Horizonte/CE
        </div>
    </header>

    <main class="w-full max-w-5xl grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
        
        <a href="https://pvelab.wl-infra.uk/" target="_blank" class="glass-card p-10 rounded-3xl transition-all duration-300 group block">
            <div class="flex items-center gap-4 mb-6">
                <div class="p-3 rounded-xl bg-amber-950/60 border border-amber-700">
                    <i data-lucide="test-tube" class="w-8 h-8 text-amber-400"></i>
                </div>
                <h2 class="text-3xl font-extrabold text-white">PVELAB</h2>
            </div>
            
            <p class="text-slate-300 text-sm mb-10 leading-relaxed font-normal">
                Nó de testes (Dell Optiplex 8080). Ambiente de homologação para novos containers CT e VMs.
            </p>
            
            <div class="flex items-center gap-2 text-lg font-bold text-cyan-400 group-hover:text-cyan-300">
                Acessar Console <i data-lucide="external-link" class="w-5 h-5 transition-transform group-hover:translate-x-1"></i>
            </div>
        </a>

        <a href="https://pvesamu.wl-infra.uk/" target="_blank" class="glass-card p-10 rounded-3xl transition-all duration-300 group block">
            <div class="flex items-center gap-4 mb-6">
                <div class="p-3 rounded-xl bg-cyan-950/60 border border-cyan-800">
                    <i data-lucide="cpu" class="w-8 h-8 text-cyan-400"></i>
                </div>
                <h2 class="text-3xl font-extrabold text-white">PVESAMU</h2>
            </div>
            
            <p class="text-slate-300 text-sm mb-10 leading-relaxed font-normal">
                Servidor de Produção. Hospeda serviços críticos, bancos de dados ativos e storage principal.
            </p>
            
            <div class="flex items-center gap-2 text-lg font-bold text-cyan-400 group-hover:text-cyan-300">
                Acessar Console <i data-lucide="external-link" class="w-5 h-5 transition-transform group-hover:translate-x-1"></i>
            </div>
        </a>

    </main>

    <footer class="mt-24 text-center">
        <div class="inline-flex items-center px-4 py-1.5 rounded-full border border-slate-700 bg-slate-900/60 text-slate-500 text-xs font-mono">
            <i data-lucide="lock" class="w-3.5 h-3.5 text-cyan-800 mr-2"></i>
            Cloudflare Zero Trust Active | MFA
        </div>
    </footer>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
