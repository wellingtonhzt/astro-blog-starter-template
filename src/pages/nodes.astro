---
// src/pages/nodes.astro
---

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WL-INFRA // ACCESS_TERMINAL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        /* FUNDO PRETO ABSOLUTO E RESET */
        html, body {
            background-color: #000000 !important;
            color: #00FF00 !important;
            font-family: 'Fira Mono', monospace;
            min-height: 100vh;
            margin: 0;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
        }

        /* TRAVAR CORES VERDES */
        body * {
            color: #00FF00 !important;
            border-color: #00FF00 !important;
        }

        .crt-glow { 
            text-shadow: 0 0 12px rgba(0, 255, 0, 0.8); 
        }
        
        /* ÍCONES VERDES */
        .fa-solid {
            color: #00FF00 !important;
            filter: drop-shadow(0 0 8px rgba(0, 255, 0, 0.6));
        }

        a { text-decoration: none !important; }

        /* ESTILO DO CARD (SEM FUNDO PARA PARECER TERMINAL PURO) */
        .terminal-block {
            background: transparent;
            border: none;
            cursor: pointer;
            transition: all 0.2s ease;
            width: 100%;
            max-width: 500px;
        }

        /* HOVER BRANCO CONFORME SOLICITADO */
        .terminal-block:hover * {
            color: #FFFFFF !important;
            border-color: #FFFFFF !important;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.8) !important;
        }

        .icon-box {
            font-size: 3.5rem;
            margin-bottom: 1.5rem;
        }

        .exec-line {
            border-left: 3px solid #00FF00;
            padding-left: 15px;
            margin-top: 10px;
            text-align: left;
        }

        .connect-box {
            border: 1px solid #00FF00;
            padding: 5px 15px;
            display: inline-block;
            margin-top: 10px;
        }
    </style>
</head>
<body class="p-10">

    <header class="text-center mb-20 crt-glow">
        <div class="text-5xl mb-4">
            <i class="fa-solid fa-terminal"></i>
        </div>
        <h1 class="text-3xl font-bold tracking-tighter">> WL-INFRA_NODES</h1>
        <p class="text-[10px] mt-2 border border-[#00FF00] inline-block px-2">[ HORIZONTE.CE // SECURED_SHELL ]</p>
    </header>

    <main class="flex flex-col items-center gap-y-32 w-full"> <a href="https://pvelab.wl-infra.uk/" target="_blank" class="terminal-block group">
            <div class="flex flex-col items-center">
                <div class="icon-box">
                    <i class="fa-solid fa-flask-vial"></i>
                </div>
                <h2 class="text-2xl font-bold mb-2 crt-glow"># pvelab.local</h2>
                <div class="text-[10px] opacity-80 mb-4">
                    [ DELL_OPTIPLEX_8080 ]<br/>
                    HOMOLOG_ENV // CT_VM_ACTIVE
                </div>
                <div class="exec-line w-full">
                    <div class="connect-box font-bold">EXEC :: CONNECT</div>
                </div>
            </div>
        </a>

        <a href="https://pvesamu.wl-infra.uk/" target="_blank" class="terminal-block group">
            <div class="flex flex-col items-center">
                <div class="icon-box">
                    <i class="fa-solid fa-microchip"></i>
                </div>
                <h2 class="text-2xl font-bold mb-2 crt-glow"># pvesamu.main</h2>
                <div class="text-[10px] opacity-80 mb-4">
                    [ PRODUCTION_ENV ]<br/>
                    VOIP_MONITOR // CRITICAL_DB
                </div>
                <div class="exec-line w-full">
                    <div class="connect-box font-bold">EXEC :: CONNECT</div>
                </div>
            </div>
        </a>

    </main>

    <footer class="mt-32 opacity-60 text-[10px] crt-glow flex items-center gap-2">
        <i class="fa-solid fa-user-shield"></i>
        [ AUTH_MFA // CLOUDFLARE_ZERO_TRUST_ENABLED ]
    </footer>

</body>
</html>
