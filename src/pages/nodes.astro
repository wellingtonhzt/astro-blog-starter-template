---
// src/pages/nodes.astro
---

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WL-INFRA // ACCESS_TERMINAL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #010409;
            color: #00FF00;
            font-family: 'Fira Mono', monospace;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            margin: 0;
            padding: 20px;
            /* Efeito de linhas de scan de TV antiga (Sutil) */
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            background-size: 100% 4px, 3px 100%;
        }

        .crt-glow { text-shadow: 0 0 10px rgba(0, 255, 0, 0.8); }
        
        a { text-decoration: none !important; }

        .terminal-card {
            background-color: rgba(0, 20, 0, 0.1);
            border: 2px solid #00FF00;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .terminal-card:hover {
            background-color: #00FF00;
            color: #010409;
            box-shadow: 0 0 40px rgba(0, 255, 0, 0.5);
        }

        .icon-box {
            font-size: 3rem;
            margin-bottom: 1.5rem;
        }
    </style>
</head>
<body>

    <header class="w-full max-w-4xl flex flex-col items-center text-center mb-16 crt-glow">
        <div class="icon-box">
            <i class="fa-solid fa-terminal"></i>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tighter">
            > WL-INFRA_NODES
        </h1>
        <div class="mt-4 text-xs font-bold border border-[#00FF00] px-4 py-1">
            [ HORIZONTE.CE // SECURED_SHELL ]
        </div>
    </header>

    <main class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-2 gap-10">
        
        <a href="https://pvelab.wl-infra.uk/" target="_blank" class="terminal-card p-10 rounded-lg block group text-center">
            <div class="icon-box">
                <i class="fa-solid fa-flask-vial"></i>
            </div>
            <h2 class="text-2xl font-bold mb-4 crt-glow group-hover:text-[#010409]"># pvelab.local</h2>
            <p class="text-xs mb-10 group-hover:text-[#010409]">
                [ DELL_OPTIPLEX_8080 ]<br/>
                HOMOLOG_ENV // CT_VM_ACTIVE
            </p>
            <div class="inline-block px-6 py-2 border-2 border-[#00FF00] font-bold group-hover:border-[#010409]">
                EXEC :: CONNECT
            </div>
        </a>

        <a href="https://pvesamu.wl-infra.uk/" target="_blank" class="terminal-card p-10 rounded-lg block group text-center">
            <div class="icon-box">
                <i class="fa-solid fa-microchip"></i>
            </div>
            <h2 class="text-2xl font-bold mb-4 crt-glow group-hover:text-[#010409]"># pvesamu.main</h2>
            <p class="text-xs mb-10 group-hover:text-[#010409]">
                [ PRODUCTION_ENV ]<br/>
                STORAGE_MASTER // CRITICAL_DB
            </p>
            <div class="inline-block px-6 py-2 border-2 border-[#00FF00] font-bold group-hover:border-[#010409]">
                EXEC :: CONNECT
            </div>
        </a>

    </main>

    <footer class="mt-20 text-center crt-glow">
        <div class="text-[10px] font-bold flex items-center justify-center gap-3">
            <i class="fa-solid fa-user-shield"></i>
            [ AUTH_MFA // CLOUDFLARE_ZERO_TRUST_ENABLED ]
        </div>
    </footer>

</body>
</html>
